{
  "name": "core-surge-arena",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @core-surge/client",
    "dev:local": "concurrently \"npm run dev --workspace @core-surge/server\" \"npm run dev --workspace @core-surge/client\"",
    "build": "npm run build --workspace @core-surge/shared && npm run build --workspace @core-surge/server && npm run build --workspace @core-surge/client",
    "start": "node server/dist/server/src/index.js",
    "test": "npm run test --workspace @core-surge/server"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^6.0.3"
  }
}
